{
  "platforms": {
    "deepseek": {
      "name": "DeepSeek",
      "url": "https://chat.deepseek.com/",
      "inputSelector": "textarea[placeholder*='发送消息'], textarea",
      "responseSelector": ".ds-markdown, .markdown-body, [class*='message-content']",
      "modeSelector": {
        "expert": "div:has-text('专家模式')",
        "fast": null
      },
      "newConversationSelector": "div:has-text('开启新对话')",
      "captchaIndicators": []
    },
    "gemini": {
      "name": "Gemini",
      "url": "https://gemini.google.com/",
      "inputSelector": "textarea, .ql-editor, [contenteditable='true']",
      "responseSelector": ".model-response-text, .response-content, [class*='message']",
      "modeSelector": null,
      "newConversationSelector": null,
      "captchaIndicators": []
    },
    "chatgpt": {
      "name": "ChatGPT",
      "url": "https://chat.openai.com/",
      "inputSelector": "textarea, #prompt-textarea",
      "responseSelector": ".markdown, [class*='message-content']",
      "modeSelector": null,
      "newConversationSelector": "nav a[href='/']",
      "captchaIndicators": [
        "iframe[src*='challenges.cloudflare.com']",
        "#challenge-running",
        "#challenge-stage",
        "[class*='cf-turnstile']",
        "input[name='cf-turnstile-response']"
      ]
    }
  }
}
